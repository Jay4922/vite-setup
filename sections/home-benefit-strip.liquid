<script src="{{ 'section-home-marquee.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="home-section home-benefit-strip section-{{ section.id }}-padding"
  style="
    --home-benefit-bg: {{ section.settings.background_color }};
    --home-benefit-text: {{ section.settings.text_color }};
    --home-benefit-icon-size: {{ section.settings.icon_size }}px;
  "
>
  <div class="home-section__container">
    <div
      class="home-benefit-strip__marquee"
      data-benefit-marquee
      style="--marquee-duration: {{ section.settings.marquee_speed }}s;"
    >
      <ul class="home-benefit-strip__track" role="list" aria-label="Wellness benefits" data-benefit-marquee-track>
        {%- for block in section.blocks -%}
          <li class="home-benefit-strip__item" data-benefit-item {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 48
                | image_tag: class: 'home-benefit-strip__icon', loading: 'lazy', widths: '24, 36, 48'
              }}
            {%- endif -%}
            <span>{{ block.settings.label | escape }}</span>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wellness Benefit Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#124A88"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Icon size",
      "default": 28
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Marquee speed",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Benefit",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Benefit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wellness Benefit Strip",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "label": "Lactose Free"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Non GMO"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Keto Friendly"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Gluten Free"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Vegan"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Stimulant Free"
          }
        },
        {
          "type": "item",
          "settings": {
            "label": "Caffeine Free"
          }
        }
      ]
    }
  ]
}
{% endschema %}
