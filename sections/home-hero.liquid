{{ 'section-home-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="home-hero section-{{ section.id }}-padding"
  style="
    --home-hero-bg: {{ section.settings.background_color }};
    --home-hero-text: {{ section.settings.text_color }};
    --home-hero-heading: {{ section.settings.heading_color }};
    --home-hero-copy: {{ section.settings.copy_color }};
    --home-hero-button-bg: {{ section.settings.button_bg_color }};
    --home-hero-button-text: {{ section.settings.button_text_color }};
  "
>
  {%- assign fallback_image = 'home-hero-master-green.png' | asset_url -%}
  <div class="home-hero__container">
    <div class="home-hero__grid">
      <div class="home-hero__content">
        <h1 class="home-hero__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h1>
        <div class="home-hero__text rte">{{ section.settings.text }}</div>
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="button button--primary home-hero__button"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
      <div class="home-hero__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              widths: '500, 750, 1000, 1300, 1600',
              sizes: '(min-width: 1800px) 52vw, (min-width: 750px) 56vw, 94vw'
          }}
        {%- else -%}
          <img
            src="{{ fallback_image }}"
            alt="Hero product image"
            width="500"
            height="500"
            loading="eager"
            fetchpriority="high"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Supplements Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Supplements You Can Trust"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h0"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Innovating through holistic formulas and advanced nutrition.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#EFBFD0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#001A38"
    },
    {
      "type": "color",
      "id": "copy_color",
      "label": "Description color",
      "default": "#001A38"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Base text color",
      "default": "#001A38"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#D91E4F"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Supplements Hero"
    }
  ]
}
{% endschema %}
