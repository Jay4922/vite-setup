<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="{{ 'section-home-sliders.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="home-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="home-section__container home-reviews">
    <header class="home-reviews__header">
      {%- if section.settings.subheading != blank -%}
        <p class="home-section__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="home-section__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </header>
    <div class="home-reviews__slider-wrap" data-home-swiper-wrap>
      <div
        class="home-swiper swiper"
        data-home-swiper
        data-swiper-kind="reviews"
        data-swiper-prev=".home-reviews-prev-{{ section.id }}"
        data-swiper-next=".home-reviews-next-{{ section.id }}"
      >
        <div class="swiper-wrapper">
          {%- assign review_count = section.blocks.size -%}
          {%- if review_count == 0 -%}
            {%- for i in (1..3) -%}
              <article class="swiper-slide home-reviews__card">
                <p class="home-reviews__meta">
                  <span class="home-reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  <span class="home-reviews__count">100 Reviews</span>
                </p>
                <h3 class="home-reviews__title">Lorem Ipsum</h3>
                <p class="home-reviews__text">
                  Lorem ipsum dolor sit amet consectetur. Cursus lorem nunc ac nibh tellus viverra et.
                </p>
                <p class="home-reviews__author">Customer Name Goes Here</p>
                <p class="home-reviews__verified">
                  <span class="home-reviews__verified-icon" aria-hidden="true">&#10003;</span>
                  <span>Verified Buyer</span>
                </p>
              </article>
            {%- endfor -%}
          {%- else -%}
            {%- for block in section.blocks -%}
              <article class="swiper-slide home-reviews__card" {{ block.shopify_attributes }}>
                <p class="home-reviews__meta">
                  <span class="home-reviews__stars">{{ block.settings.stars | escape }}</span>
                  <span class="home-reviews__count">{{ block.settings.reviews_count | escape }}</span>
                </p>
                <h3 class="home-reviews__title">{{ block.settings.title | escape }}</h3>
                <p class="home-reviews__text">{{ block.settings.text | escape }}</p>
                <p class="home-reviews__author">{{ block.settings.author | escape }}</p>
                <p class="home-reviews__verified">
                  <span class="home-reviews__verified-icon" aria-hidden="true">&#10003;</span>
                  <span>{{ block.settings.verified | escape }}</span>
                </p>
              </article>
            {%- endfor -%}
            {%- if review_count < 4 -%}
              {%- for block in section.blocks -%}
                <article class="swiper-slide home-reviews__card" aria-hidden="true">
                  <p class="home-reviews__meta">
                    <span class="home-reviews__stars">{{ block.settings.stars | escape }}</span>
                    <span class="home-reviews__count">{{ block.settings.reviews_count | escape }}</span>
                  </p>
                  <h3 class="home-reviews__title">{{ block.settings.title | escape }}</h3>
                  <p class="home-reviews__text">{{ block.settings.text | escape }}</p>
                  <p class="home-reviews__author">{{ block.settings.author | escape }}</p>
                  <p class="home-reviews__verified">
                    <span class="home-reviews__verified-icon" aria-hidden="true">&#10003;</span>
                    <span>{{ block.settings.verified | escape }}</span>
                  </p>
                </article>
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
      <div class="home-slider-nav home-reviews__nav">
        <button
          class="home-slider-button home-reviews__arrow home-slider-prev home-reviews-prev-{{ section.id }}"
          type="button"
          aria-label="Previous"
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <button
          class="home-slider-button home-reviews__arrow home-slider-next home-reviews-next-{{ section.id }}"
          type="button"
          aria-label="Next"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "REVIEWS"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What People Are Saying"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "stars",
          "label": "Stars",
          "default": "★★★★★"
        },
        {
          "type": "text",
          "id": "reviews_count",
          "label": "Review count",
          "default": "100 Reviews"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lorem Ipsum"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "Lorem ipsum dolor sit amet consectetur. Cursus lorem nunc ac nibh tellus viverra et."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Customer Name Goes Here"
        },
        {
          "type": "text",
          "id": "verified",
          "label": "Verified label",
          "default": "Verified Buyer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Slider",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
