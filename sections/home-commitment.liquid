{{ 'section-home-commitment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="home-commitment color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="home-commitment__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="home-commitment__heading inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    <ul class="home-commitment__list" role="list">
      {%- for block in section.blocks -%}
        <li class="home-commitment__item" {{ block.shopify_attributes }}>
          <div class="home-commitment__badge">
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 180
                | image_tag:
                  class: 'home-commitment__image',
                  loading: 'lazy',
                  widths: '90, 120, 180, 240',
                  sizes: '(min-width: 990px) 12vw, (min-width: 750px) 22vw, 44vw'
              }}
            {%- elsif block.settings.text != blank -%}
              <span class="home-commitment__text">{{ block.settings.text | escape }}</span>
            {%- else -%}
              <span class="home-commitment__text">{{ 'Image or text' }}</span>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Our Commitment to Quality",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Our Commitment to Quality"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Fallback text",
          "default": "Quality badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Commitment to Quality",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "text": "Busted"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Made in USA"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "GMP"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Third party tested"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Non GMO"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "NSF"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "FDA facility"
          }
        }
      ]
    }
  ]
}
{% endschema %}
