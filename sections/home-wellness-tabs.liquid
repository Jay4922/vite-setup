{{ 'section-home-wellness.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-home-wellness.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="home-wellness color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  data-home-wellness
  style="
    --home-wellness-bg: {{ section.settings.background_color }};
    --home-wellness-tabs-bg: {{ section.settings.tabs_background_color }};
    --home-wellness-tab-text: {{ section.settings.tab_text_color }};
    --home-wellness-tab-active-bg: {{ section.settings.tab_active_background_color }};
    --home-wellness-tab-active-text: {{ section.settings.tab_active_text_color }};
    --home-wellness-title: {{ section.settings.product_title_color }};
    --home-wellness-price: {{ section.settings.price_color }};
    --home-wellness-button-bg: {{ section.settings.button_background_color }};
    --home-wellness-button-text: {{ section.settings.button_text_color }};
    --home-wellness-arrow-color: {{ section.settings.arrow_color }};
  "
>
  {%- assign fallback_images = 'home-product-master-green.png|home-product-master-cell.png|home-product-nitro.png|home-product-master-green-alt.png'
    | split: '|'
  -%}
  <div class="home-wellness__container">
    <header class="home-wellness__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="home-wellness__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div
        class="home-wellness__tabs"
        role="tablist"
        aria-label="{{ section.settings.heading | default: 'Product tabs' | escape }}"
      >
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="home-wellness__tab"
            role="tab"
            data-wellness-tab="{{ block.id }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            {% unless forloop.first %}
              tabindex="-1"
            {% endunless %}
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label | escape }}
          </button>
        {%- endfor -%}
      </div>
    </header>

    {%- if section.blocks.size == 0 -%}
      <p class="home-wellness__empty">{{ 'Add tab blocks and select a collection for each tab.' }}</p>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- assign tab_collection = block.settings.collection -%}
      {%- assign scoped_section_id = section.id | append: '-' | append: block.id -%}
      <div class="home-wellness__panel{% if forloop.first %} is-active{% endif %}" data-wellness-panel="{{ block.id }}">
        <div class="home-wellness__carousel" data-home-swiper-wrap>
          <button
            class="home-wellness__control home-wellness__control--prev home-slider-prev home-wellness-prev-{{ section.id }}-{{ block.id }}"
            type="button"
            aria-label="Previous products"
          >
            <span aria-hidden="true">&larr;</span>
          </button>
          <div
            class="home-wellness__swiper swiper"
            data-home-swiper
            data-swiper-kind="wellness"
            data-swiper-prev=".home-wellness-prev-{{ section.id }}-{{ block.id }}"
            data-swiper-next=".home-wellness-next-{{ section.id }}-{{ block.id }}"
            data-swiper-pagination=".home-wellness-pagination-{{ section.id }}-{{ block.id }}"
          >
            <div class="swiper-wrapper">
              {%- if tab_collection != blank and tab_collection.products_count > 0 -%}
                {%- for product in tab_collection.products limit: section.settings.products_to_show -%}
                  <div class="swiper-slide home-wellness__slide">
                    <article class="home-wellness__product-card">
                      <a class="home-wellness__image-link" href="{{ product.url }}">
                        <div class="home-wellness__image-wrap">
                          {%- if product.featured_image != blank -%}
                            {{
                              product.featured_image
                              | image_url: width: 640
                              | image_tag:
                                loading: 'lazy',
                                widths: '220, 320, 460, 640',
                                sizes: '(min-width: 990px) 18vw, (min-width: 750px) 30vw, 72vw',
                                class: 'home-wellness__image'
                            }}
                          {%- else -%}
                            {%- assign fallback_index = forloop.index0 | modulo: fallback_images.size -%}
                            {%- assign fallback_image = fallback_images[fallback_index] | asset_url -%}
                            <img
                              class="home-wellness__image"
                              src="{{ fallback_image }}"
                              alt="{{ product.title | escape }}"
                              loading="lazy"
                              width="242"
                              height="430"
                            >
                          {%- endif -%}
                        </div>
                      </a>
                      <div class="home-wellness__product-info">
                        <p class="home-wellness__badge">{{ section.settings.tag_label | escape }}</p>
                        <h3 class="home-wellness__product-title">
                          <a href="{{ product.url }}">{{ product.title | escape }}</a>
                        </h3>
                        <p class="home-wellness__stars">{{ section.settings.stars_text | escape }}</p>
                        <p class="home-wellness__product-price">{{ product.price | money }}</p>
                        {%- assign first_variant = product.selected_or_first_available_variant -%}
                        {%- if first_variant != blank and product.has_only_default_variant -%}
                          <product-form data-section-id="{{ scoped_section_id }}">
                            {%-
                              form 'product',
                              product,
                              id: 'QuickAdd-' | append: scoped_section_id | append: '-' | append: product.id,
                              class: 'home-wellness__product-form'
                            -%}
                              <input type="hidden" name="id" value="{{ first_variant.id }}">
                              <button
                                type="submit"
                                name="add"
                                class="home-wellness__quick-add"
                                {% unless first_variant.available %}
                                  disabled
                                {% endunless %}
                              >
                                {{ section.settings.quick_add_label | escape }}
                              </button>
                            {%- endform -%}
                          </product-form>
                        {%- else -%}
                          <a class="home-wellness__quick-add" href="{{ product.url }}">
                            {{ section.settings.quick_add_label | escape }}
                          </a>
                        {%- endif -%}
                      </div>
                    </article>
                  </div>
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..4) -%}
                  {%- assign fallback_index = forloop.index0 | modulo: fallback_images.size -%}
                  {%- assign fallback_image = fallback_images[fallback_index] | asset_url -%}
                  <div class="swiper-slide home-wellness__slide">
                    <article class="home-wellness__placeholder-card">
                      <div class="home-wellness__placeholder-media">
                        <img
                          src="{{ fallback_image }}"
                          alt="Placeholder product"
                          loading="lazy"
                          width="242"
                          height="430"
                        >
                      </div>
                      <h3 class="home-wellness__placeholder-title">Product name</h3>
                      <p class="home-wellness__placeholder-price">$0.00</p>
                      <button type="button" class="button button--primary home-wellness__placeholder-button" disabled>
                        {{ section.settings.quick_add_label | escape }}
                      </button>
                    </article>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
          <button
            class="home-wellness__control home-wellness__control--next home-slider-next home-wellness-next-{{ section.id }}-{{ block.id }}"
            type="button"
            aria-label="Next products"
          >
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
        <div class="home-slider-nav">
          <div class="home-slider-pagination home-wellness-pagination-{{ section.id }}-{{ block.id }}"></div>
        </div>
        {%- if tab_collection == blank -%}
          <p class="home-wellness__empty">{{ 'Select a collection for this tab.' }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Start Your Wellness",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Start Your Wellness"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Products to show",
      "default": 8
    },
    {
      "type": "text",
      "id": "quick_add_label",
      "label": "Fallback button label",
      "default": "Quick Add"
    },
    {
      "type": "text",
      "id": "tag_label",
      "label": "Badge label",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "stars_text",
      "label": "Stars text",
      "default": "★★★★★"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt", "label": "Adapt" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "adapt"
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "Image shape",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "arch", "label": "Arch" },
        { "value": "blob", "label": "Blob" },
        { "value": "chevronleft", "label": "Chevron left" },
        { "value": "chevronright", "label": "Chevron right" },
        { "value": "diamond", "label": "Diamond" },
        { "value": "parallelogram", "label": "Parallelogram" },
        { "value": "round", "label": "Round" }
      ],
      "default": "default"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "tabs_background_color",
      "label": "Tabs background",
      "default": "#E2E9F1"
    },
    {
      "type": "color",
      "id": "tab_text_color",
      "label": "Tab text color",
      "default": "#124A88"
    },
    {
      "type": "color",
      "id": "tab_active_background_color",
      "label": "Active tab background",
      "default": "#124A88"
    },
    {
      "type": "color",
      "id": "tab_active_text_color",
      "label": "Active tab text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title color",
      "default": "#124A88"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#001A38"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Quick add button background",
      "default": "#D71E47"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Quick add button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Slider arrow color",
      "default": "#D71E47"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collection tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Best Sellers"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Start Your Wellness",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "tab_label": "Best Sellers"
          }
        },
        {
          "type": "tab",
          "settings": {
            "tab_label": "Bundles"
          }
        }
      ]
    }
  ]
}
{% endschema %}
