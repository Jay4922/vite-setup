{
  "name": "vite-setup",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npx @tailwindcss/cli -i css/application.css -o assets/application.css.liquid -w\" \"shopify theme dev\"",
    "build": "vite build && npx @tailwindcss/cli -i css/application.css -o assets/application.css.liquid -m",
    "format": "prettier --write snippets/ templates/ sections/ layout/ config/ assets/",
    "lint": "eslint . --ext .js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{js,jsx,ts,tsx,css,md,liquid}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jay4922/vite-setup.git"
  },
  "bugs": {
    "url": "https://github.com/Jay4922/vite-setup/issues"
  },
  "homepage": "https://github.com/Jay4922/vite-setup#readme",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@shopify/prettier-plugin-liquid": "^1.10.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "vite": "^5.1.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}
